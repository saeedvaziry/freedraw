{
  "name": "@freedraw/diagram",
  "version": "0.2.1",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Embeddable renderer for FreeDraw diagram code (a Mermaid flowchart subset). Turn text into a canvas diagram.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saeedvaziry/freedraw.git",
    "directory": "packages/diagram"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && rollup -c rollup.dts.config.js && rm -rf dist/types",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@freedraw/config": "*",
    "@freedraw/engine": "*",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "happy-dom": "^20.10.6",
    "perfect-freehand": "^1.2.3",
    "roughjs": "^4.6.6",
    "rollup": "^4.61.1",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
